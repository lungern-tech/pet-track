+    private var dragTrackingDisplayLink: CADisplayLink?
+    private weak var dragTrackingMarkerView: MarkerView?
     private var zoomVelocity: Double = 0
     private let friction: Double = 0.92 // 摩擦系数，越接近 1 滑得越远
     private let velocityThreshold: Double = 0.001 // 停止阈值
@@ -1380,9 +1383,14 @@ extension ExpoGaodeMapView {
                 switch newState {
                 case .starting:
                     markerView.onMarkerDragStart(event)
+                    startMarkerDragTracking(markerView: markerView, annotation: annotation)
                 case .dragging:
                     markerView.onMarkerDrag(event)
+                    if dragTrackingDisplayLink == nil {
+                        startMarkerDragTracking(markerView: markerView, annotation: annotation)
+                    }
                 case .ending, .canceling:
+                    stopMarkerDragTracking()
                     markerView.onMarkerDragEnd(event)
                 default:
                     break
@@ -1392,6 +1400,34 @@ extension ExpoGaodeMapView {
         }
 
     }
+
+    private func startMarkerDragTracking(markerView: MarkerView, annotation: MAAnnotation) {
+        stopMarkerDragTracking()
+        dragTrackingMarkerView = markerView
+        let link = CADisplayLink(target: self, selector: #selector(handleMarkerDragTrackingTick(_:)))
+        link.add(to: .main, forMode: .common)
+        dragTrackingDisplayLink = link
+    }
+
+    private func stopMarkerDragTracking() {
+        dragTrackingDisplayLink?.invalidate()
+        dragTrackingDisplayLink = nil
+        dragTrackingMarkerView = nil
+    }
+
+    @objc private func handleMarkerDragTrackingTick(_ link: CADisplayLink) {
+        guard let markerView = dragTrackingMarkerView,
+              let annotation = markerView.annotation else {
+            stopMarkerDragTracking()
+            return
+        }
+
+        let coord = annotation.coordinate
+        markerView.onMarkerDrag([
+            "latitude": coord.latitude,
+            "longitude": coord.longitude,
+        ])
+    }
 }
 
